---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const photos = [
  { src: `${base}images/Combat%20Robotics/02D83855747A3AA3DD194A3B6D85FD95.png`, alt: 'Combat robotics test build', category: 'Combat Robotics', size: 'large' },
  { src: `${base}images/Combat%20Robotics/CAD84AA3-8542-4606-A5DC-B878B2DB9862.jpg`, alt: 'Combat robotics team photo', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/B9E49CEA-55FB-427F-B580-94D13033A84E.jpg`, alt: 'Combat robotics assembly', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0556.jpg`, alt: 'Combat robotics close-up', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/2E6CA53948386972C3F1978441B3E75A.png`, alt: 'Combat robotics CAD rendering', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/DB755629-E323-4910-8573-251C83CFBD44.jpg`, alt: 'Combat robotics team build photo', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0648.jpg`, alt: 'Combat robotics hardware detail', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0677.jpg`, alt: 'Combat robotics build session', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0759.jpg`, alt: 'Combat robotics test day', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0760.jpg`, alt: 'Combat robotics drivetrain', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0761.jpg`, alt: 'Combat robotics team build', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/IMG_0763.jpg`, alt: 'Combat robotics event setup', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Combat%20Robotics/Test_Two_v2_DCProject__2025_10_12_17_00_18.png`, alt: 'Combat robotics CAD concept', category: 'Combat Robotics', size: 'small' },
  { src: `${base}images/Drone/image.png`, alt: 'Drone platform in testing', category: 'Drone', size: 'large' },
  { src: `${base}images/Drone/aerial.png`, alt: 'Aerial drone platform', category: 'Drone', size: 'small' },
  { src: `${base}images/Drone/68792591330__7A4233E5-0C54-4E37-BDD2-CDBA8CFBEF5E_Original.png`, alt: 'Drone build photo', category: 'Drone', size: 'small' },
  { src: `${base}images/Drone/IMG_3854_Original.png`, alt: 'Drone team photo', category: 'Drone', size: 'small' },
  { src: `${base}images/Mini%20bot/IMG_0396.png`, alt: 'Mini bot line follower setup', category: 'Mini Bot', size: 'large' },
  { src: `${base}images/Mini%20bot/IMG_0393.png`, alt: 'Mini bot team demo', category: 'Mini Bot', size: 'small' },
  { src: `${base}images/Mini%20bot/IMG_0394.png`, alt: 'Mini bot test run', category: 'Mini Bot', size: 'small' },
  { src: `${base}images/Mini%20bot/IMG_0397.png`, alt: 'Mini bot close-up', category: 'Mini Bot', size: 'small' },
  { src: `${base}images/Mini%20bot/20250222_171231.png`, alt: 'Mini bot workshop moment', category: 'Mini Bot', size: 'small' },
  { src: `${base}images/Quadruped/image.png`, alt: 'Quadruped robot prototype', category: 'Quadruped', size: 'small' },
  { src: `${base}images/image%20(1).png`, alt: 'Club activity photo', category: 'General', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/IMG_0448.png`, alt: 'Engineering Club Day showcase', category: 'Outreach', size: 'large' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/WhiteBot.png`, alt: 'Engineering Club Day robot display', category: 'Outreach', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/YellowBot.png`, alt: 'Engineering Club Day yellow bot', category: 'Outreach', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/20250513_191503.png`, alt: 'Engineering Club Day event photo', category: 'Outreach', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/20250513_192712.png`, alt: 'Engineering Club Day booth photo', category: 'Outreach', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/IMG_0446.png`, alt: 'Engineering Club Day crowd shot', category: 'Outreach', size: 'small' },
  { src: `${base}images/2025%20Engineering%20Club%20Day/IMG_0447.png`, alt: 'Engineering Club Day robotics demo', category: 'Outreach', size: 'small' },
];

const categories = ['All', ...new Set(photos.map(p => p.category))];
---

<Layout title="Gallery" description="Photos from UC Davis Robotics Club — lab work, competitions, and workshops.">

  <section class="page-hero section">
    <div class="container">
      <p class="section-label">In pictures</p>
      <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Gallery</h1>
      <p class="section-body">A look at what goes on in the lab, at competitions, and in the community.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Category filter -->
      <div class="filter-bar" id="filterBar">
        {categories.map(c => (
          <button class:list={['filter-btn', c === 'All' ? 'active' : '']} data-cat={c}>
            {c}
          </button>
        ))}
      </div>

      <!-- Masonry-style grid -->
      <div class="gallery-grid" id="galleryGrid">
        {photos.map(p => (
          <div class="gallery-item" data-cat={p.category} data-size={p.size}>
            <img src={p.src} alt={p.alt} class="gallery-img" loading="lazy" decoding="async" />
            <div class="gallery-overlay">
              <p class="gallery-caption">{p.alt}</p>
              <span class="gallery-cat">{p.category}</span>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- Submit photo CTA -->
  <section class="section" style="background:var(--surface);border-top:1px solid var(--border);">
    <div class="container" style="max-width:580px; text-align:center; margin-inline:auto;">
      <p class="section-label">Contribute</p>
      <h2 class="section-title" style="font-size:2rem;">Got a photo to share?</h2>
      <p class="section-body" style="margin-inline:auto; margin-bottom:2rem;">
        If you attended an event or captured something cool in the lab, send it our way.
      </p>
      <a href={`${base}join`} class="btn btn-outline">Submit a Photo</a>
    </div>
  </section>

</Layout>

<style>
.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2.5rem;
}

.filter-btn {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.4em 1em;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
}

.filter-btn:hover, .filter-btn.active {
  background: var(--gold);
  color: #000;
  border-color: var(--gold);
}

/* CSS columns masonry */
.gallery-grid {
  columns: 3;
  column-gap: 12px;
}

.gallery-item {
  break-inside: avoid;
  margin-bottom: 12px;
  position: relative;
  overflow: hidden;
  border-radius: 6px;
  cursor: pointer;
}

.gallery-item[data-size="large"] .gallery-img { height: 340px; }
.gallery-item[data-size="small"] .gallery-img { height: 200px; }

.gallery-img { width: 100%; border-radius: 6px; object-fit: cover; display: block; }

.gallery-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 60%);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 1rem;
  opacity: 0;
  transition: opacity 0.2s;
}

.gallery-item:hover .gallery-overlay { opacity: 1; }

.gallery-caption {
  font-size: 0.85rem;
  font-weight: 600;
  color: #fff;
  margin-bottom: 0.25rem;
}

.gallery-cat {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--gold);
}

/* hidden by filter */
.gallery-item.hidden { display: none; }

@media (max-width: 860px) { .gallery-grid { columns: 2; } }
@media (max-width: 500px) { .gallery-grid { columns: 1; } }
</style>

<script>
const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
const items = document.querySelectorAll<HTMLElement>('.gallery-item');

filterBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    filterBtns.forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const cat = btn.dataset.cat;
    items.forEach(item => {
      item.classList.toggle('hidden', cat !== 'All' && item.dataset.cat !== cat);
    });
  });
});
</script>
