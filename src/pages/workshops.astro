---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const upcoming = [
  { title: 'Intro to ROS2', date: 'Oct 12, 2025', time: '3–5 PM', location: 'Kemper 1065', level: 'Beginner' },
  { title: 'SolidWorks for Robots', date: 'Oct 19, 2025', time: '2–4 PM', location: 'Bainer 1132', level: 'Beginner' },
  { title: 'PCB Design with KiCad', date: 'Oct 26, 2025', time: '4–6 PM', location: 'Kemper 1065', level: 'Intermediate' },
  { title: 'Computer Vision with OpenCV', date: 'Nov 2, 2025', time: '3–5 PM', location: 'Zoom + Kemper', level: 'Intermediate' },
];

const past = [
  { title: 'Soldering Fundamentals', img: '[ soldering workshop ]' },
  { title: 'Arduino Crash Course', img: '[ arduino workshop ]' },
  { title: 'PID Control Theory', img: '[ PID workshop ]' },
  { title: 'Intro to SLAM', img: '[ SLAM workshop ]' },
];
---

<Layout title="Workshops" description="Hands-on robotics workshops hosted by UC Davis Robotics Club.">

  <section class="page-hero section">
    <div class="container">
      <p class="section-label">Learn by doing</p>
      <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Workshops</h1>
      <p class="section-body">
        Free workshops open to all UC Davis students. We cover hardware, software, and
        everything in between — no experience required for beginner sessions.
      </p>
    </div>
  </section>

  <!-- Upcoming -->
  <section class="section">
    <div class="container">
      <p class="section-label">This quarter</p>
      <h2 class="section-title">Upcoming Workshops</h2>
      <div class="workshop-list">
        {upcoming.map(w => (
          <div class="workshop-row">
            <div class="workshop-date-col">
              <p class="workshop-date">{w.date}</p>
              <p class="workshop-time">{w.time}</p>
            </div>
            <div class="workshop-info">
              <h3 class="workshop-title">{w.title}</h3>
              <p class="workshop-loc">📍 {w.location}</p>
            </div>
            <span class:list={['level-badge', w.level === 'Beginner' ? 'level-beg' : 'level-int']}>
              {w.level}
            </span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Past workshops photo grid -->
  <section class="section" style="background:var(--surface); border-block:1px solid var(--border);">
    <div class="container">
      <p class="section-label">Archive</p>
      <h2 class="section-title">Past Workshops</h2>
      <div class="past-grid">
        {past.map(p => (
          <div class="past-card">
            <div class="img-placeholder past-img">{p.img}</div>
            <p class="past-title">{p.title}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Host a workshop CTA -->
  <section class="section">
    <div class="container" style="max-width:640px;">
      <p class="section-label">Contribute</p>
      <h2 class="section-title" style="font-size:2rem;">Want to lead a workshop?</h2>
      <p class="section-body" style="margin-bottom:2rem;">
        If you have expertise in a robotics-adjacent topic, we'd love to have you teach.
        Members and non-members alike are welcome to propose a session.
      </p>
      <a href={`${base}contact`} class="btn btn-primary">Get in Touch</a>
    </div>
  </section>

</Layout>

<style>
.workshop-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 2.5rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.workshop-row {
  display: grid;
  grid-template-columns: 180px 1fr auto;
  align-items: center;
  gap: 1.5rem;
  padding: 1.4rem 1.75rem;
  border-bottom: 1px solid var(--border);
  background: var(--surface);
  transition: background 0.15s;
}

.workshop-row:last-child { border-bottom: none; }
.workshop-row:hover { background: var(--surface-2); }

.workshop-date {
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--text);
}

.workshop-time {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
}

.workshop-title {
  font-size: 1rem;
  font-weight: 700;
  color: var(--text);
  margin-bottom: 0.3rem;
}

.workshop-loc {
  font-size: 0.8rem;
  color: var(--text-muted);
}

.level-badge {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.25em 0.75em;
  border-radius: 999px;
  white-space: nowrap;
}

.level-beg { background: rgba(34,197,94,0.1); color: #4ade80; border: 1px solid rgba(34,197,94,0.25); }
.level-int { background: rgba(201,168,76,0.1); color: var(--gold); border: 1px solid rgba(201,168,76,0.25); }

.past-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.25rem;
  margin-top: 2.5rem;
}

.past-card { display: flex; flex-direction: column; gap: 0.75rem; }
.past-img { height: 180px; border-radius: 6px; }
.past-title { font-size: 0.875rem; font-weight: 600; color: var(--text); }

@media (max-width: 600px) {
  .workshop-row { grid-template-columns: 1fr; }
  .workshop-date-col { display: flex; gap: 1rem; align-items: baseline; }
}
</style>
