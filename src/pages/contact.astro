---
import Layout from '../layouts/Layout.astro';

const joinUrl = `${import.meta.env.BASE_URL}join`;
---

<Layout title="Join the Club" description="Join and contact UC Davis Robotics Club.">
  <script define:vars={{ joinUrl }}>
    window.location.replace(joinUrl);
  </script>
  <section class="page-hero section">
    <div class="container">
      <p class="section-label">Membership</p>
      <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Join the Club</h1>
      <p class="section-body">
        Contact details have moved to the Join Us page.
      </p>
      <a href={joinUrl} class="btn btn-primary" style="margin-top:2rem;">Go to Join Us</a>
    </div>
  </section>
</Layout>
