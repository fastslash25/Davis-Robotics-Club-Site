---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="container hero-content">
      <p class="hero-eyebrow">UC Davis · Est. 2018</p>
      <h1 class="hero-title">
        We Build<br />
        <span class="hero-title-gold">Robots.</span>
      </h1>
      <p class="hero-body">
        A student-run club at UC Davis where engineers, designers, and makers collaborate on all things robotics.
      </p>
      <div class="hero-actions">
        <a href={`${base}join`} class="btn btn-primary">Join the Club</a>
        <a href={`${base}projects`} class="btn btn-outline">See Our Work</a>
      </div>
    </div>

    <div class="hero-img-grid container">
      <div class="hero-img" style="height:320px;">
        <img src={`${base}images/Combat%20Robotics/DB755629-E323-4910-8573-251C83CFBD44.jpg`} alt="UC Davis Robotics Club robot" loading="lazy" decoding="async" />
      </div>
      <div class="hero-img-col">
        <div class="hero-img" style="height:152px;">
          <img src={`${base}images/Mini%20bot/IMG_0396.png`} alt="Workshop activity" loading="lazy" decoding="async" />
        </div>
        <div class="hero-img" style="height:152px;">
          <img src={`${base}images/Drone/image.png`} alt="Competition drone" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <!-- ── FEATURED PROJECTS ── -->
  <section class="section">
    <div class="container">
      <p class="section-label">What we build</p>
      <h2 class="section-title">Featured Projects</h2>
      <div class="projects-grid">
        {[
          { title: 'Combat Robotics', tag: 'Combat', desc: 'A student-built combat robot platform designed for fast iteration, robust drivetrain design, and high-impact demonstrations.', image: `${base}images/Combat%20Robotics/02D83855747A3AA3DD194A3B6D85FD95.png` },
          { title: 'Drone Platform', tag: 'Aerial', desc: 'Custom quadrotor designed for computer vision and precision agriculture research.', image: `${base}images/Drone/image.png` },
          { title: 'Mini Bot Line Follower', tag: 'Controls', desc: 'A beginner-friendly line-following robot used to teach sensors, control loops, and embedded programming.', image: `${base}images/Mini%20bot/IMG_0396.png` },
        ].map(p => (
          <a href={`${base}projects`} class="project-card">
            <div class="project-img" style="height:200px;">
              <img src={p.image} alt={p.title} loading="lazy" decoding="async" />
            </div>
            <div class="project-info">
              <span class="project-tag">{p.tag}</span>
              <h3 class="project-title">{p.title}</h3>
              <p class="project-desc">{p.desc}</p>
            </div>
          </a>
        ))}
      </div>
      <a href={`${base}projects`} class="btn btn-outline" style="margin-top:2.5rem;">All Projects →</a>
    </div>
  </section>

  <!-- ── GALLERY STRIP ── -->
  <!-- Temporarily disabled.
  <section class="gallery-strip">
    <div class="container">
      <p class="section-label">Club life</p>
      <h2 class="section-title">In the Lab & Beyond</h2>
    </div>
    <div class="strip-grid">
      {Array(5).fill(null).map((_, i) => (
        <div class="strip-img img-placeholder">[ photo {i+1} ]</div>
      ))}
    </div>
    <div class="container" style="margin-top:1.5rem;">
      <a href={`${base}gallery`} class="btn btn-outline">Full Gallery →</a>
    </div>
  </section>
  -->

  <!-- ── JOIN CTA ── -->
  <section class="section cta-section">
    <div class="container cta-inner">
      <div>
        <p class="section-label">Get involved</p>
        <h2 class="section-title" style="margin-bottom:1rem;">Ready to build something?</h2>
        <p class="section-body">No experience required — just curiosity. We welcome all majors and skill levels.</p>
      </div>
      <a href={`${base}join`} class="btn btn-primary">Apply Now</a>
    </div>
  </section>

</Layout>

<style>
/* ── Hero ── */
.hero {
  padding-top: calc(var(--nav-h) + 80px);
  padding-bottom: 0;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 60% at 60% 20%, rgba(0,40,85,0.45) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 1;
  padding-bottom: 3rem;
}

.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.75rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.25rem;
}

.hero-title {
  font-size: clamp(3.5rem, 8vw, 6.5rem);
  font-weight: 800;
  line-height: 1.0;
  margin-bottom: 1.5rem;
}

.hero-title-gold { color: var(--gold); }

.hero-body {
  font-size: 1.1rem;
  color: var(--text-muted);
  max-width: 48ch;
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

.hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }

/* hero image grid */
.hero-img-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-top: 3rem;
  padding-bottom: 0;
  position: relative;
  z-index: 1;
}

.hero-img-col {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.hero-img {
  border-radius: 6px;
  overflow: hidden;
  border: 1px solid var(--border);
  background: var(--surface);
  box-shadow: 0 18px 60px rgba(0, 0, 0, 0.26);
}

.hero-img img,
.project-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* ── Stats ── */
.stats-bar {
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
  padding-block: 2.5rem;
  background: var(--surface);
}

.stats-inner {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
  gap: 2rem;
}

.stat { text-align: center; }

.stat-n {
  font-family: var(--font-display);
  font-size: 2.75rem;
  font-weight: 800;
  color: var(--gold);
  line-height: 1;
}

.stat-label {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-top: 0.4rem;
  font-family: var(--font-mono);
  letter-spacing: 0.08em;
}

/* ── Projects grid ── */
.projects-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 2.5rem;
}

.project-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  transition: border-color 0.2s, transform 0.2s;
}

.project-card:hover {
  border-color: var(--gold-dim);
  transform: translateY(-3px);
}

.project-info { padding: 1.5rem; }

.project-tag {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
}

.project-title {
  font-size: 1.2rem;
  font-weight: 700;
  margin: 0.5rem 0 0.75rem;
  color: var(--text);
}

.project-desc {
  font-size: 0.875rem;
  color: var(--text-muted);
  line-height: 1.65;
}

/* ── Gallery strip ── */
.gallery-strip { padding-block: var(--section-gap); background: var(--surface); }

.strip-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
  margin-top: 2.5rem;
  overflow-x: auto;
}

.strip-img {
  height: 280px;
  border-radius: 4px;
  min-width: 200px;
}

/* ── CTA section ── */
.cta-section { background: var(--surface-2); border-block: 1px solid var(--border); }

.cta-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 2rem;
  flex-wrap: wrap;
}

@media (max-width: 640px) {
  .hero-img-grid { grid-template-columns: 1fr; }
  .hero-img-col { display: none; }
  .strip-grid { grid-template-columns: repeat(3, 1fr); }
}
</style>
