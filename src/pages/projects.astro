---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL;

const projects = [
  {
    title: 'Combat Robotics',
    tag: 'Combat · Hardware',
    status: 'Active',
    year: '2025',
    desc: 'A student-built combat robot platform focused on robust drivetrain design, fast iteration, and high-impact demonstrations. The project brings together mechanical fabrication, controls, and testing in a highly hands-on environment.',
    tech: ['Fabrication', 'Controls', 'Testing', 'CAD'],
    image: `${base}images/Combat%20Robotics/02D83855747A3AA3DD194A3B6D85FD95.png`,
  },
  {
    title: 'Engineering Club Day Showcase',
    tag: 'Outreach · Demo',
    status: 'Active',
    year: '2025',
    desc: 'A hands-on robotics showcase built for Engineering Club Day, featuring interactive bots and demonstrations that introduce students to mechanical, electrical, and software systems.',
    tech: ['Rapid Prototyping', 'Embedded Systems', 'Outreach', 'CAD'],
    image: `${base}images/2025%20Engineering%20Club%20Day/IMG_0448.png`,
  },
  {
    title: 'Drone Platform',
    tag: 'Aerial · Autonomy',
    status: 'Active',
    year: '2025',
    desc: 'A custom aerial platform for flight testing, visual sensing, and autonomous navigation experiments. The project focuses on reliable hardware integration and flight stability.',
    tech: ['ROS2', 'Computer Vision', 'Python', 'Flight Control'],
    image: `${base}images/Drone/image.png`,
  },
  {
    title: 'Mini Bot Line Follower',
    tag: 'Beginner · Controls',
    status: 'Active',
    year: '2025',
    desc: 'A beginner-friendly line-following robot used to teach sensor calibration, control loops, and embedded programming in a compact build.',
    tech: ['Arduino', 'PID', 'IR Sensors', 'C++'],
    image: `${base}images/Mini%20bot/IMG_0396.png`,
  },
  {
    title: 'Quadruped Robot',
    tag: 'Legged Locomotion',
    status: 'In Development',
    year: '2025',
    desc: 'A compact quadruped platform exploring gait control, balance, and legged locomotion. The build is focused on making complex motion systems approachable for student teams.',
    tech: ['Embedded C++', 'IMU', 'Servo Motors', 'Control Theory'],
    image: `${base}images/Quadruped/image.png`,
  },
];
---

<Layout title="Projects" description="Explore robotics projects built by UC Davis Robotics Club members.">

  <section class="page-hero section">
    <div class="container">
      <p class="section-label">What we build</p>
      <h1 class="section-title" style="font-size:clamp(2.5rem,5vw,4rem);">Our Projects</h1>
      <p class="section-body">
        From competition rovers to research platforms — every project is designed, built,
        and tested by students at Davis.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="projects-list">
        {projects.map((p, i) => (
          <div class="project-row">
            <div class="project-img-wrap">
              <img src={p.image} alt={p.title} class="project-img" loading="lazy" decoding="async" />
            </div>
            <div class="project-detail">
              <div class="project-meta">
                <span class="project-tag-text">{p.tag}</span>
                <span class:list={['project-status', p.status === 'Active' ? 'status-active' : p.status === 'Planning' ? 'status-plan' : 'status-done']}>
                  {p.status}
                </span>
              </div>
              <h2 class="proj-title">{p.title}</h2>
              <p class="proj-desc">{p.desc}</p>
              <div class="tech-stack">
                {p.tech.map(t => <span class="tech-tag">{t}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
.projects-list {
  display: flex;
  flex-direction: column;
  gap: 4rem;
}

.project-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
  padding-bottom: 4rem;
  border-bottom: 1px solid var(--border);
}

.project-row:last-child { border-bottom: none; }

.project-row:nth-child(even) .project-img { order: 2; }
.project-row:nth-child(even) .project-detail { order: 1; }

.project-meta {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}

.project-tag-text {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--gold);
}

.project-status {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.2em 0.65em;
  border-radius: 999px;
}

.status-active  { background: rgba(34,197,94,0.12); color: #4ade80; border: 1px solid rgba(34,197,94,0.3); }
.status-done    { background: rgba(100,100,120,0.2); color: var(--text-dim); border: 1px solid var(--border); }
.status-plan    { background: rgba(201,168,76,0.1); color: var(--gold); border: 1px solid rgba(201,168,76,0.3); }

.proj-title {
  font-size: clamp(1.5rem, 3vw, 2rem);
  font-weight: 800;
  margin-bottom: 1rem;
  color: var(--text);
}

.proj-desc {
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.75;
  margin-bottom: 1.5rem;
}

.tech-stack {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.tech-tag {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  padding: 0.3em 0.75em;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--text-muted);
}

 .project-img-wrap {
  height: 260px;
  border-radius: 6px;
  overflow: hidden;
  background: var(--surface);
  border: 1px solid var(--border);
}

.project-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.project-row:nth-child(3) .project-img {
  object-position: center 35%;
  transform: scale(1.08);
}

@media (max-width: 700px) {
  .project-row { grid-template-columns: 1fr; }
  .project-row:nth-child(even) .project-img-wrap { order: 0; }
  .project-row:nth-child(even) .project-detail { order: 0; }
}
</style>
